{
    "activateModules": {
        "attachments": true,
        "downloadTempFiles": false,
        "hcube": false,
        "loadLocal": true,
        "logFile": true,
        "lstFile": false
    },
    "aggregateWidgets": true,
    "autoGenInputGraphs": true,
    "customCss": false,
    "dataRendering": {
         "_scalars_out": {
            "label": "KPI – Dashboard",
            "options": [
                {
                    "served_demand": {
                        "color": "aqua",
                        "description": "Served Demand",
                        "icon": {
                            "lib": "font-awesome",
                            "name": "face-smile"
                        },
                        "round": 2
                    },
                    "total_demand": {
                        "color": "aqua",
                        "description": "Total Demand",
                        "icon": {
                            "lib": "font-awesome",
                            "name": "users"
                        },
                        "round": 2
                    },
                    "unserved_demand": {
                        "color": "aqua",
                        "description": "Unserved Demand",
                        "icon": {
                            "lib": "font-awesome",
                            "name": "ban"
                        },
                        "round": 2
                    }
                },
                {
                    "avg_walking_dist": {
                        "color": "green",
                        "description": "Avg Walking Dist in [m]",
                        "icon": {
                            "lib": "font-awesome",
                            "name": "house-chimney"
                        },
                        "round": 2
                    },
                    "coverage_pct": {
                        "color": "green",
                        "description": "Coverage in [%]",
                        "icon": {
                            "lib": "font-awesome",
                            "name": "star"
                        },
                        "round": 2
                    },
                    "num_built_stops": {
                        "color": "green",
                        "description": "Number of Stops Built",
                        "icon": {
                            "lib": "font-awesome",
                            "name": "circle-exclamation"
                        },
                        "round": 2
                    }
                },
                {
                    "cost_per_stop_value": {
                        "color": "red",
                        "description": "Cost per Bus Stop in [€]",
                        "icon": {
                            "lib": "font-awesome",
                            "name": "euro-sign"
                        },
                        "round": 2
                    },
                    
                    "total_cost_bus_stops_used": {
                        "color": "red",
                        "description": "Total Costs for Bus Stops in [€]",
                        "icon": {
                            "lib": "font-awesome",
                            "name": "euro-sign"
                        },
                        "round": 2
                    },
                    "min_stops_needed_msg": {
                        "color": "yellow",
                        "description": "Minimum Number of Stops – to achieve required coverage",
                        "icon": {
                            "lib": "font-awesome",
                            "name": "circle-exclamation"
                        },
                        "round": 2
                    }
                }
            ],
            "outType": "valueBox"
        },
        "map_data": {
            "graph": {
                "layersControl": {
                    "options": {
                        "collapsed": true
                    },
                    "position": "topright"
                },
                "markers": {
                    "1": {
                        "iconOptions": {
                            "icon": "circle",
                            "iconColor": "",
                            "markerColor": "blue"
                        },
                        "label": "",
                        "labelOptions": {
                            "permanent": true,
                            "textsize": "12px"
                        },
                        "lat": "lat",
                        "lng": "lon"
                    }
                },
                "tool": "leaflet"
            },
            "height": 700,
            "label": "All Candidate Bus Stops",
            "outType": "graph"
        },
        "map_data_filtered": {
            "graph": {
                "layersControl": {
                    "options": {
                        "collapsed": true
                    },
                    "position": "topright"
                },
                "markers": {
                    "1": {
                        "iconOptions": {
                            "icon": "circle",
                            "iconColor": "#000000",
                            "markerColor": "red"
                        },
                        "label": "[j], [served]",
                        "labelOptions": {
                            "permanent": false,
                            "style": {
                                "background-color": "#ffffff",
                                "color": "#000000"
                            },
                            "textsize": "12px"
                        },
                        "lat": "lat",
                        "lng": "lon"
                    }
                },
                "tool": "leaflet"
            },
            "height": 700,
            "label": "Bus Stops Built",
            "outType": "graph"
        }
    },
    "datatable": {
        "class": "cell-border",
        "filter": "bottom",
        "options": {
            "pageLength": 20
        },
        "rownames": false
    },
    "defaultRendererOutput": "miroPivot",
    "defaultScenName": "default",
    "defCompMode": "split",
    "excelIncludeEmptySheets": true,
    "excelIncludeMeta": true,
    "handsontable": {
        "colWidths": 200,
        "contextMenu": {
            "allowColEdit": true,
            "allowRowEdit": true,
            "enabled": true
        },
        "height": 700,
        "readonly": false,
        "stretchH": "none"
    },
    "inputWidgets": {
        "alpha": {
            "default": 0.5,
            "label": "Alpha",
            "max": 1,
            "min": 0,
            "noHcube": false,
            "step": 0.025,
            "ticks": true,
            "tooltip": "1= full benefit for the society - focus on max. coverage and reduce walking distance ; 0= full focus on minimizing cost",
            "widgetType": "slider"
        },
        "min_coverage_pct": {
            "default": 0,
            "label": "Minimum Coverage Percentage",
            "max": 100,
            "min": 0,
            "noHcube": false,
            "step": 1,
            "ticks": true,
            "tooltip": "How high should the coverage at least be",
            "widgetType": "slider"
        },
        "p": {
            "default": 20,
            "label": "Max. Stops to Open",
            "max": 400,
            "min": 1,
            "noHcube": false,
            "step": 1,
            "ticks": true,
            "widgetType": "slider"
        },
        "r": {
            "default": 400,
            "label": "Max. Walking Distance",
            "max": 1000,
            "min": 10,
            "noHcube": false,
            "step": 10,
            "ticks": true,
            "widgetType": "slider"
        },
        "cost_per_stop": {
            "decimal": 0,
            "decimalCharacter": ".",
            "digitGroupSeparator": ",",
            "label": "Cost for one Bus Stop",
            "max": 500000,
            "min": 20000,
            "sign": "€ ",
            "value": 60000,
            "widgetType": "numericinput"
        }
    },
    "layoutSettings": {
        "maxTabsExpandedInput": 5,
        "maxTabsExpandedOutput": 5,
        "maxTabsExpandedPivotComp": 5,
        "maxTabsExpandedSplitComp": 5,
        "maxTabsExpandedTabComp": 5
    },
    "outputTables": {
        "map_data": {
            "class": "cell-border",
            "filter": "bottom",
            "options": {
                "decimals": 10,
                "pageLength": 20
            },
            "rownames": false
        }
    },
    "overwriteAliases": {
        "_scalars": {
            "newAlias": "Scalars"
        },
        "_scalars_out": {
            "newAlias": "Output Scalars"
        },
        "alpha": {
            "newAlias": "Weight: 1=Max Profit, 0=Max Service"
        },
        "avg_walking_dist": {
            "newAlias": "Avg Walking Dist (m)"
        },
        "cost_per_stop": {
            "newAlias": "Cost for one Bus Stop"
        },
        "cost_per_stop_value": {
            "newAlias": "Cost per Bus Stop"
        },
        "coverage_pct": {
            "newAlias": "coverage_pct"
        },
        "map_data": {
            "newAlias": "Candidate Bus Stops"
        },
        "map_data_filtered": {
            "newAlias": "Built Stops Only"
        },
        "min_coverage_pct": {
            "newAlias": "Minimum Coverage Percentage"
        },
        "min_stops_needed_msg": {
            "newAlias": "minimum of stops needed"
        },
        "num_built_stops": {
            "newAlias": "Number of Stops Built"
        },
        "p": {
            "newAlias": "Max Stops to Open"
        },
        "r": {
            "newAlias": "Service Radius (m)"
        },
        "served_demand": {
            "newAlias": "served_demand"
        },
        "total_cost_bus_stops_used": {
            "newAlias": "Total costs for Bus Stops used"
        },
        "total_demand": {
            "newAlias": "total_demand"
        },
        "unserved_demand": {
            "newAlias": "unserved_demand"
        }
    },
    "overwriteSheetOrder": {
        "input": "_widgets"
    },
    "pageTitle": "Bus Stop Location App",
    "parseLogForMiroLogSyntax": true,
    "pivotCompSettings": {
        "emptyUEL": "-",
        "fixedColumns": true,
        "hideEmptyCols": false,
        "hidePivotControls": false,
        "tableSummarySettings": {
            "colEnabled": false,
            "colSummaryFunction": "sum",
            "rowEnabled": false,
            "rowSummaryFunction": "sum"
        }
    },
    "roundingDecimals": 2,
    "storeLogFilesDuration": 7,
    "theme": "browser"
}
